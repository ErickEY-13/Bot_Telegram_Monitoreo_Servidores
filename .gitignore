# =============================================
# .gitignore - Bot Telegram Monitoreo Servidores
# =============================================

# Entorno virtual Python
venv/
env/
.venv/

# Variables de entorno con credenciales reales
.env

# Cache de Python
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Base de datos local
historial.db
*.db

# Scripts de despliegue con credenciales
remote_deploy.py
fix_deploy.py

# Archivos del sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Editores e IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# Archivos temporales
*.tmp
*.bak
