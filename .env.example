# ============================================================
# Archivo de ejemplo para variables de entorno (.env)
# Copia este archivo como .env y llena los valores reales
# ============================================================

# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Chat ID autorizado para ejecutar comandos de reinicio
# Puedes obtenerlo enviándole un mensaje a @userinfobot en Telegram
AUTHORIZED_CHAT_ID=123456789

# Chat ID donde se enviarán las alertas automáticas de monitoreo
# Puede ser el mismo que AUTHORIZED_CHAT_ID o un grupo
ALERT_CHAT_ID=123456789

# Configuración SSH para MV2 (servidor remoto)
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USER=tu_usuario
SSH_PASSWORD=tu_contraseña

# También puedes usar clave SSH en lugar de contraseña:
# SSH_KEY_PATH=/home/tu_usuario/.ssh/id_rsa
# SSH_KEY_PASSPHRASE=  (dejar vacío si no tiene passphrase)
